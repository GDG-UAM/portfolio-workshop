---
/**
 * Container — Centered max-width wrapper.
 *
 * Usage:
 *   <Container>
 *     <h1>Content goes here</h1>
 *   </Container>
 *
 *   <Container narrow>
 *     <p>Narrower reading width</p>
 *   </Container>
 */
interface Props {
  narrow?: boolean;
  class?: string;
}

const { narrow = false, class: className } = Astro.props;
---

<div class:list={['container', { 'container--narrow': narrow }, className]}>
  <slot />
</div>

<style>
  .container {
    width: 100%;
    max-width: var(--max-width);
    margin-inline: auto;
    padding-inline: var(--space-md);
  }

  .container--narrow {
    max-width: var(--content-width);
  }
</style>
