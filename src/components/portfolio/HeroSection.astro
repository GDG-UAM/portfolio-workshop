---
/**
 * HeroSection — The prominent intro section at the top of the homepage.
 *
 * Displays: avatar, name, role, tagline, location, social links, CTA button.
 */
import SocialLinks from '../ui/SocialLinks.astro';
import Button from '../ui/Button.astro';
import { getCollection } from 'astro:content';

const profileEntries = await getCollection('profile');
const profile = profileEntries[0]?.data;

if (!profile) {
  throw new Error('Profile data not found. Check src/data/profile.yaml');
}
---

<section class="hero" aria-label="Introduction">
  <div class="hero__container">
    <div class="hero__content">
      {/* Decorative gradient background (only visible in Bold theme) */}
      <div class="hero__bg" aria-hidden="true"></div>

      <div class="hero__text">
        {
          profile.avatar && (
            <img
              src={profile.avatar}
              alt={`Photo of ${profile.name}`}
              class="hero__avatar"
              width="96"
              height="96"
              loading="eager"
            />
          )
        }

        <h1 class="hero__name">{profile.name}</h1>
        <p class="hero__role">{profile.role}</p>
        <p class="hero__tagline">{profile.tagline}</p>

        {
          profile.location && (
            <p class="hero__location">
              <svg
                viewBox="0 0 24 24"
                width="16"
                height="16"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z" />
                <circle cx="12" cy="10" r="3" />
              </svg>
              {profile.location}
            </p>
          )
        }

        <div class="hero__actions">
          <SocialLinks github={profile.github} linkedin={profile.linkedin} email={profile.email} />
          <Button href="#about" variant="outline" size="sm"> More about me ↓ </Button>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding-block: var(--space-3xl) var(--space-2xl);
    overflow: hidden;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    background: var(--hero-gradient);
    opacity: 0.6;
    pointer-events: none;
  }

  .hero__container {
    position: relative;
    z-index: 1;
    max-width: var(--max-width);
    margin-inline: auto;
    padding-inline: var(--space-md);
  }

  .hero__content {
    max-width: 42rem;
  }

  .hero__text {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .hero__avatar {
    width: 5rem;
    height: 5rem;
    border-radius: var(--radius-full);
    object-fit: cover;
    border: 3px solid var(--color-border);
    margin-bottom: var(--space-2xs);
  }

  @media (min-width: 768px) {
    .hero__avatar {
      width: 6rem;
      height: 6rem;
    }
  }

  .hero__name {
    font-size: var(--font-size-4xl);
    font-weight: var(--font-weight-bold);
    letter-spacing: -0.03em;
    line-height: 1.1;
  }

  @media (min-width: 768px) {
    .hero__name {
      font-size: var(--font-size-5xl);
    }
  }

  .hero__role {
    font-size: var(--font-size-lg);
    color: var(--color-accent);
    font-weight: var(--font-weight-medium);
  }

  .hero__tagline {
    font-size: var(--font-size-md);
    color: var(--color-text-muted);
    max-width: 38ch;
    line-height: var(--line-height-normal);
  }

  .hero__location {
    display: inline-flex;
    align-items: center;
    gap: 0.35em;
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-md);
    margin-top: var(--space-sm);
  }
</style>
