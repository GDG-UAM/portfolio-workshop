---
/**
 * VolunteeringItem — A single volunteering entry.
 */
import { formatDateRange } from '../../utils/formatDate';

interface Props {
  organization: string;
  role: string;
  url?: string;
  startDate: Date;
  endDate?: Date;
  description: string;
  contributions: string[];
}

const { organization, role, url, startDate, endDate, description, contributions } = Astro.props;
const dateRange = formatDateRange(startDate, endDate);
---

<article class="vol-item">
  <div class="vol-item__dot" aria-hidden="true"></div>

  <div class="vol-item__content">
    <header class="vol-item__header">
      <h3 class="vol-item__role">{role}</h3>
      <p class="vol-item__org">
        {
          url ? (
            <a href={url} target="_blank" rel="noopener noreferrer">
              {organization}
            </a>
          ) : (
            organization
          )
        }
      </p>
      <time class="vol-item__date">{dateRange}</time>
    </header>

    <p class="vol-item__description">{description}</p>

    {
      contributions.length > 0 && (
        <ul class="vol-item__contributions">
          {contributions.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      )
    }
  </div>
</article>

<style>
  .vol-item {
    position: relative;
    padding-left: var(--space-lg);
    padding-bottom: var(--space-xl);
  }

  .vol-item::before {
    content: '';
    position: absolute;
    left: 5px;
    top: 10px;
    bottom: 0;
    width: 1px;
    background: var(--timeline-color);
  }

  .vol-item:last-child::before {
    display: none;
  }

  .vol-item:last-child {
    padding-bottom: 0;
  }

  .vol-item__dot {
    position: absolute;
    left: 0;
    top: 6px;
    width: 11px;
    height: 11px;
    border-radius: 50%;
    background: var(--color-accent);
    border: 2px solid var(--color-bg);
    box-shadow: 0 0 0 2px var(--color-accent);
  }

  .vol-item__content {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
  }

  .vol-item__header {
    display: flex;
    flex-direction: column;
    gap: var(--space-3xs);
  }

  .vol-item__role {
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-semibold);
    color: var(--color-heading);
  }

  .vol-item__org {
    font-size: var(--font-size-base);
    color: var(--color-text);
  }

  .vol-item__org a {
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .vol-item__date {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    font-variant-numeric: tabular-nums;
  }

  .vol-item__description {
    font-size: var(--font-size-base);
    color: var(--color-text-muted);
    line-height: var(--line-height-normal);
  }

  .vol-item__contributions {
    display: flex;
    flex-direction: column;
    gap: var(--space-3xs);
    padding-left: var(--space-sm);
    list-style: disc;
    margin-top: var(--space-2xs);
  }

  .vol-item__contributions li {
    font-size: var(--font-size-sm);
    color: var(--color-text);
    line-height: var(--line-height-normal);
  }
</style>
