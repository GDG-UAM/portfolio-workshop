---
/**
 * Button — A styled link or button element.
 *
 * Usage:
 *   <Button href="/posts">Read my posts</Button>
 *   <Button href="https://github.com" variant="outline" external>GitHub</Button>
 */
interface Props {
  href?: string;
  variant?: 'primary' | 'outline' | 'ghost';
  size?: 'sm' | 'md';
  external?: boolean;
  class?: string;
}

const { href, variant = 'primary', size = 'md', external = false, class: className } = Astro.props;

const Tag = href ? 'a' : 'button';
const externalAttrs = external ? { target: '_blank', rel: 'noopener noreferrer' } : {};
---

<Tag
  href={href}
  class:list={['btn', `btn--${variant}`, `btn--${size}`, className]}
  {...externalAttrs}
>
  <slot />
</Tag>

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    font-weight: var(--font-weight-medium);
    border-radius: var(--radius-md);
    cursor: pointer;
    border: none;
    text-decoration: none;
    transition:
      background-color var(--transition-fast),
      color var(--transition-fast),
      box-shadow var(--transition-fast),
      transform var(--transition-fast);
    line-height: 1.4;
  }

  .btn:hover {
    transform: translateY(-1px);
  }

  .btn:active {
    transform: translateY(0);
  }

  /* Sizes */
  .btn--sm {
    padding: 0.4em 1em;
    font-size: var(--font-size-sm);
  }

  .btn--md {
    padding: 0.6em 1.4em;
    font-size: var(--font-size-base);
  }

  /* Variants */
  .btn--primary {
    background: var(--color-accent);
    color: var(--color-accent-text);
  }

  .btn--primary:hover {
    background: var(--color-accent-hover);
    color: var(--color-accent-text);
    box-shadow: var(--shadow-md);
  }

  .btn--outline {
    background: transparent;
    color: var(--color-accent);
    box-shadow: inset 0 0 0 1.5px var(--color-accent);
  }

  .btn--outline:hover {
    background: var(--color-accent-subtle);
    color: var(--color-accent-hover);
  }

  .btn--ghost {
    background: transparent;
    color: var(--color-text-muted);
  }

  .btn--ghost:hover {
    color: var(--color-text);
    background: var(--color-bg-alt);
  }
</style>
